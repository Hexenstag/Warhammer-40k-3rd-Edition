                <rule name="Psycannon Bolts" id="d223-f6f0-4846-8f1f" hidden="false">
                  <description>Any bolter equiped by the model with Psycannon Bolts upgrades their AP to AP4. Only Armour saves may be taken against Psycannon Bolts. Invulnerable saves are ignored.</description>
                </rule>
                <rule name="Member of the Osiron" id="b2ba-36c1-57a3-9309" hidden="false">
                  <description>The Seneschals of the Enochian Guard are well versed in the mysteries of the warp. The Enochian Seneschal may count as a psyker when he is attempting to use his Force Halberd.</description>
                </rule>
              </rules>
