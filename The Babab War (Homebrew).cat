      <rules>
        <rule name="Hard to Kill" id="1007-1a48-3895-68f2" hidden="false">
          <description>When a Venerable Dreadnought takes a glancing or penetrating hit, you may force your opponent to re-roll the resulting damage. You must accept the result of the second roll, even if it is worse.</description>
        </rule>
        <rule name="Old &amp; Wise" id="4b55-73bf-9d15-6224" hidden="false">
          <description>If a Sons of Medusa army includes a Venerable Forge-Lord it may re-roll the dice if the mission being played has a dice roll to see who gets the first turn.</description>
        </rule>
        <rule name="Living Icon of the Chapter" id="7947-3ea3-ac4d-053f" hidden="false">
          <description>Any Howling Griffons unit with at least 1 model with 6&quot; of Chaplain Titus automatically pass all Morale Checks. Conversely, if Titus is destroyed, any Howling Griffons with line of sight to him must take a pinning check at -1 Leadership.</description>
        </rule>
      </rules>
      <modifiers>
        <modifier type="add" value="Chaplain Dreadnought Armand Titus cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="281b-c3d3-cdc9-3ef0" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
