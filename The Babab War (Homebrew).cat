    <selectionEntry type="upgrade" import="true" name="Iron Thane&apos;s Cybernetic Augmentations" hidden="false" id="aa67-d96d-a159-0c56">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="93c7-3fe8-afdb-1b9a" includeChildSelections="true"/>
      </constraints>
      <rules>
        <rule name="Purge the Weak" id="3b66-aa00-c347-9836" hidden="false">
          <description>Devastators upgraded by the Iron Thane gain +1 Toughness, are immune to all Morale Checks, and gain the Bionics upgrade at no additional cost.</description>
        </rule>
      </rules>
      <modifiers>
        <modifier type="increment" value="10" field="4ed5-2f92-9abc-2870">
          <repeats>
