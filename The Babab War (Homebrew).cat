                <selectionEntry type="upgrade" import="true" name="Multi-Melta" hidden="false" id="83bb-5fb3-d375-cd81" collective="false">
                  <infoLinks>
                    <infoLink name="Multi-melta" id="846b-920a-a347-3fd0" hidden="false" targetId="7077-4e34-5c92-5320" type="profile"/>
                  </infoLinks>
                  <costs>
                    <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="35"/>
                  </costs>
                  <comment>Star Phantoms</comment>
                  <modifiers>
                    <modifier type="set" value="true" field="hidden">
                      <comment>Star Phantoms</comment>
                      <conditions>
                        <condition type="notInstanceOf" value="1" field="selections" scope="parent" childId="80a0-9a53-e345-0687" shared="true"/>
                      </conditions>
                    </modifier>
                    <modifier type="add" value="Star Phantoms can only replace one Lascannon with either a Plasma Cannon or Multi-Melta." field="error">
                      <comment>Star Phantoms can only use one of these, not both</comment>
                      <conditionGroups>
                        <conditionGroup type="and">
                          <conditions>
                            <condition type="atLeast" value="1" field="selections" scope="parent" childId="83bb-5fb3-d375-cd81" shared="true"/>
                            <condition type="atLeast" value="1" field="selections" scope="parent" childId="87c1-0c3e-1985-6e30" shared="true"/>
                          </conditions>
                        </conditionGroup>
                      </conditionGroups>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="dfe9-7ed7-d9e8-cc76"/>
                  </constraints>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
        </entryLink>
      </entryLinks>
      <rules>
        <rule name="Master of the 9th" id="e842-bc2c-3234-1251" hidden="false">
          <description>As the master of the Star Phantoms Devastator Company, Androcles often deploys with a formidable number of Devastators in his force.


0-1 Devastator Squads may be taken as a Troops choice if Androcles is part of the army.</description>
        </rule>
        <rule name="Tenacious Attacker" id="7fc8-c16e-ecba-dfbf" hidden="false">
          <description>If Zhurkal Androcles is in the enemy deployment zone, he and the squad he is attached to gain the Ignore Injuries special rules while they remain wholly within the deployment zone.</description>
        </rule>
        <rule name="Ignore Injuries" id="fb92-bb83-81e6-f828" hidden="false">
          <description>If active (see Tenacious Attacker rule) the following applies.


If a model with this rule loses its final wound, roll a dice. On a 1, 2 or 3 remove the model as normal. On a 4, 5 or 6 the model ignores the lost wound and stays on the table. This ability has no effect against wounds caused by weapons that inflict the Instant Death rule or against close combat weapons that allows no armour saves.</description>
        </rule>
      </rules>
      <modifiers>
        <modifier type="add" value="Captain Zhrukhal Androcles cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="3482-6b22-bdc9-8d50" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <infoLinks>
