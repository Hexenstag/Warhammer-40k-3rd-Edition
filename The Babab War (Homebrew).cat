                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Once per game; Roll an extra D6 to penetrate vehicles at half range.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Terminator Armour" id="1793-ba1c-6b00-b011" hidden="false" type="rule" targetId="fe7a-62df-712a-5bc5"/>
            <infoLink name="Iron Halo" id="ec46-ffd2-115b-27e7" hidden="false" type="rule" targetId="c214-19e6-edea-0f81"/>
