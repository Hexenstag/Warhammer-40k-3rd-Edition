      </categoryLinks>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="250"/>
      </costs>
      <modifiers>
        <modifier type="add" value="Lord Asterion Moloc cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="a837-42c6-fcc4-1b34" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <selectionEntries>
