          </constraints>
          <profiles>
            <profile name="Tyberos The Red Wake" typeId="1e16-2bd8-7cad-379b" typeName="Unit" hidden="false" id="8e6b-65da-d2e8-ed42">
              <characteristics>
                <characteristic name="WS" typeId="c704-6128-f143-935a">5</characteristic>
                <characteristic name="BS" typeId="7928-3a9b-6080-ed95">5</characteristic>
                <characteristic name="S" typeId="df03-6292-d3f5-f778">5</characteristic>
                <characteristic name="T" typeId="e5f6-94c4-de8c-5fa8">4</characteristic>
                <characteristic name="W" typeId="4dc2-c603-0bc5-0561">3</characteristic>
                <characteristic name="I" typeId="eeda-4fb4-901e-b70d">5</characteristic>
                <characteristic name="A" typeId="abbf-0d11-fd86-d938">4</characteristic>
                <characteristic name="Ld" typeId="f47e-b15a-8f58-703c">10</characteristic>
                <characteristic name="Sv" typeId="b309-5233-122f-82bb">2+</characteristic>
              </characteristics>
            </profile>
            <profile name="Hunger &amp; Slake" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="cee8-7a28-839c-14bc">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">As User</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">1</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Melee</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Master-Crafted; See rules</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Terminator Armour" id="183c-d638-ad3a-6daf" hidden="false" type="rule" targetId="fe7a-62df-712a-5bc5"/>
            <infoLink name="Deep Strike" id="31dd-5ce3-3862-eee2" hidden="false" type="rule" targetId="5715-6219-5059-9bcf"/>
            <infoLink name="Teleport Homer" id="720a-6fb2-f769-d4a4" hidden="false" type="rule" targetId="250f-507f-ea1b-b164"/>
          </infoLinks>
          <rules>
            <rule name="Hunger &amp; Slake" id="cfd1-825b-9120-f700" hidden="false">
              <description>Tyberor&apos;s weapons, Hunger &amp; Slake, are a pair of unique power weapons. One is a Master-Crafted Lighting Claw, and the second is a Master-Crafted Chainfist. He may divide up his close combat attacks freely between the two weapons (extra attack already included in profile).</description>
            </rule>
            <rule name="Shade Master" id="7c0e-3688-bdc8-3119" hidden="false">
              <description>Tyberos the Red Wake may re-roll any failed Pinning or Morale Checks.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <rules>
        <rule name="Circling Predators" id="48a6-c3a2-cb14-459d" hidden="false">
          <description>In a turn in which a Tyberos and his Red Brethren Terminator Squad Deep Strikes onto the battlefield, they may move D3&quot; towards the nearest enemy unit during the assault phase. If they move into base contact, they count as being engaged in close combat and may fight in melee that turn, but they do not count as charging.</description>
        </rule>
        <rule name="Red Brethren" id="7ddd-0010-5858-ab3f" hidden="false">
          <description>If Tyberos is accompanied by a Red Brethren Terminator Squad, both he and the squad automatically pass all Pinning and Morale Checks they are required to make.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Independent Character" id="2705-906d-4bc1-4e1e" hidden="false" type="rule" targetId="4a60-7f7e-c37f-a4d6"/>
      </infoLinks>
      <modifiers>
        <modifier type="add" value="Tyberos cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="0fea-6343-575d-301b" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
    </selectionEntry>
